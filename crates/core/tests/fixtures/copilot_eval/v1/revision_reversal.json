{
  "schema_version": 1,
  "id": "synthetic-approve-to-reject",
  "description": "A slow partial-grounded response is cancelled when Approve is revised to Reject.",
  "content_origin": "synthetic",
  "goal": "Protect the rollout decision from ambiguity.",
  "synthesize_partials": false,
  "transcript": [
    {
      "utterance_sequence": 1,
      "offset_ms": 0,
      "duration_ms": 1200,
      "final_text": "Reject the rollout until the security review is complete.",
      "partials": [
        {
          "at_ms": 300,
          "text": "Approve the rollout"
        },
        {
          "at_ms": 380,
          "text": "Reject the rollout"
        }
      ]
    }
  ],
  "labels": {
    "opportunities": [
      {
        "id": "protect-rejection-condition",
        "start_ms": 350,
        "end_ms": 1300,
        "kind": "Watch",
        "match_any": ["security review", "reject"]
      }
    ],
    "no_opportunity_ranges": [
      {
        "id": "unstable-approve-prefix",
        "start_ms": 0,
        "end_ms": 340
      }
    ],
    "revision_reversals": [
      {
        "utterance_sequence": 1,
        "from_contains": "Approve",
        "to_contains": "Reject"
      }
    ]
  },
  "mock_script": [
    {
      "cue": {
        "update_kind": "partial",
        "utterance_sequence": 1,
        "text_contains": "Approve"
      },
      "first_token_ms": 120,
      "completion_ms": 300,
      "draft": {
        "kind": "Say",
        "text": "Confirm that the rollout is approved.",
        "source_chip": "approve rollout"
      }
    },
    {
      "cue": {
        "update_kind": "final",
        "utterance_sequence": 1,
        "text_contains": "Reject"
      },
      "first_token_ms": 20,
      "completion_ms": 65,
      "draft": {
        "kind": "Watch",
        "text": "Keep the rollout rejected until the security review is complete.",
        "source_chip": "security review condition"
      }
    }
  ]
}
