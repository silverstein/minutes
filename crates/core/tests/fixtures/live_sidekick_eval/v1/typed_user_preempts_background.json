{
  "schema_version": 1,
  "id": "typed-user-preempts-background",
  "description": "A typed user turn cancels background work before any other visible action.",
  "content_origin": "synthetic",
  "privacy": {
    "generation_method": "behavior_first_from_scratch",
    "source_material": "none",
    "approved_role_tokens": ["USER", "PARTICIPANT_A"]
  },
  "matrix": {
    "surfaces": ["terminal", "gui"],
    "capture_modes": ["live", "recording"]
  },
  "initial_state": {
    "user_role": "participant",
    "posture": "strategist"
  },
  "events": [
    {
      "at_ms": 0,
      "kind": "capture_started",
      "session_id": "SESSION_A",
      "payload": {"capture_mode": "live", "capture_session_id": "CAPTURE_A"}
    },
    {
      "at_ms": 10,
      "kind": "background_started",
      "session_id": "SESSION_A",
      "payload": {"run_id": "BACKGROUND_A"}
    },
    {
      "at_ms": 20,
      "kind": "transcript_final",
      "session_id": "SESSION_A",
      "payload": {
        "capture_session_id": "CAPTURE_A",
        "event_id": "EVENT_A",
        "speaker": "PARTICIPANT_A",
        "text": "the review has moved to a new section"
      }
    },
    {
      "at_ms": 30,
      "kind": "user_message",
      "session_id": "SESSION_A",
      "payload": {"turn_id": "FOREGROUND_A", "source_event_id": "USER_EVENT_A", "text": "what changed"}
    }
  ],
  "expectations": {
    "ordered_actions": ["cancel_background", "acknowledge_user", "dispatch_foreground"],
    "forbidden_actions": ["analyze_new_evidence_before_user_ack", "publish_stale_background"],
    "state_equals": {"active_foreground_turn": "FOREGROUND_A", "background_active": false},
    "required_source_kinds": ["user_statement"],
    "required_source_event_ids": [],
    "provenance_required": true,
    "max_unsolicited_messages": 0,
    "parity_group": "foreground-priority"
  },
  "execution": {
    "status": "executable",
    "target": "core_reducer",
    "replays": [
      {
        "name": "typed-user-preemption",
        "session_id": "SESSION_A",
        "surface": "terminal",
        "event_indexes": [0, 1, 2, 3],
        "expected_reductions": [
          {"accepted": true, "actions": [{"type": "live_transcript_attached", "capture_session_id": "CAPTURE_A"}], "rejection": null},
          {"accepted": true, "actions": [{"type": "background_invocation_registered", "run_id": "BACKGROUND_A", "invocation": {"sequence": 1, "source_policy_generation": 0, "user_generation": 0}}], "rejection": null},
          {"accepted": true, "actions": [{"type": "evidence_accepted", "evidence_id": "EVENT_A", "source_kind": "transcript_final"}], "rejection": null},
          {"accepted": true, "actions": [
            {"type": "cancel_background", "run_id": "BACKGROUND_A", "invocation": {"sequence": 1, "source_policy_generation": 0, "user_generation": 0}, "reason": "typed_user_input"},
            {"type": "acknowledge_foreground", "turn_id": "FOREGROUND_A", "invocation": {"sequence": 2, "source_policy_generation": 0, "user_generation": 1}},
            {"type": "request_read_only_foreground_inference", "turn_id": "FOREGROUND_A", "invocation": {"sequence": 2, "source_policy_generation": 0, "user_generation": 1}, "source_event_id": "USER_EVENT_A", "text": "what changed"}
          ], "rejection": null}
        ],
        "expected_state": {
          "scope": "live_capture", "surface": "terminal_sidekick", "phase": "ready",
          "user_role": {"value": "participant", "revision": 0, "supersedes_revision": null, "source_event_id": null},
          "posture": "strategist", "capture_mode": "live", "capture_session_id": "CAPTURE_A",
          "finalized_meeting_ref": null, "source_policy_generation": 0, "user_generation": 1, "provider_capabilities": null,
          "foreground_turn": {"id": "FOREGROUND_A", "source_event_id": "USER_EVENT_A", "invocation": {"sequence": 2, "source_policy_generation": 0, "user_generation": 1}}, "background_run": null,
          "evidence": {
            "EVENT_A": {"id": "EVENT_A", "source_kind": "transcript_final", "capture_session_id": "CAPTURE_A", "finalized_meeting_ref": null},
            "USER_EVENT_A": {"id": "USER_EVENT_A", "source_kind": "user_statement", "capture_session_id": "CAPTURE_A", "finalized_meeting_ref": null}
          }, "speaker_corrections": {}
        }
      }
    ]
  }
}
